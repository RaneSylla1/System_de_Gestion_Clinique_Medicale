<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">
    <persistence-unit name="sgcmPU">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>sn.clinique.sgcm.model.Patient</class>
        <class>sn.clinique.sgcm.model.Medecin</class>
        <class>sn.clinique.sgcm.model.Utilisateur</class>
        <class>sn.clinique.sgcm.model.RendezVous</class>
        <class>sn.clinique.sgcm.model.Consultation</class>
        <class>sn.clinique.sgcm.model.Facture</class>

        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/clinique_db"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/> <property name="jakarta.persistence.jdbc.password" value=""/> <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>

            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/> <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>