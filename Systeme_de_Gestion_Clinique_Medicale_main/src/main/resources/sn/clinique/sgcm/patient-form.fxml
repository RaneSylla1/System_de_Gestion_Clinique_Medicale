<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.clinique.sgcm.controller.PatientFormController"
      style="-fx-background-color: #1a1a2e;"
      spacing="16" prefWidth="500">

    <padding><Insets top="24" left="28" right="28" bottom="24"/></padding>

    <Label fx:id="formTitle" text="Nouveau Patient"
           style="-fx-text-fill: white; -fx-font-size: 18px;
                  -fx-font-weight: bold;"/>

    <Separator style="-fx-background-color: #0f3460;"/>


    <HBox spacing="12">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Nom *"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <TextField fx:id="nomField" promptText="Nom"
                       style="-fx-background-color: #16213e;
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #606080;
                              -fx-background-radius: 8;
                              -fx-border-color: #0f3460;
                              -fx-border-radius: 8; -fx-border-width: 1;
                              -fx-padding: 8 12 8 12;"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Prénom *"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <TextField fx:id="prenomField" promptText="Prénom"
                       style="-fx-background-color: #16213e;
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #606080;
                              -fx-background-radius: 8;
                              -fx-border-color: #0f3460;
                              -fx-border-radius: 8; -fx-border-width: 1;
                              -fx-padding: 8 12 8 12;"/>
        </VBox>
    </HBox>


    <HBox spacing="12">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Date de naissance *"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <DatePicker fx:id="dateNaissanceField"
                        style="-fx-background-color: #16213e;
                               -fx-border-color: #0f3460;
                               -fx-border-radius: 8; -fx-border-width: 1;
                               -fx-background-radius: 8;"
                        maxWidth="Infinity"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Sexe *"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <ComboBox fx:id="sexeField" maxWidth="Infinity"
                      style="-fx-background-color: #16213e;
                             -fx-border-color: #0f3460;
                             -fx-border-radius: 8; -fx-border-width: 1;
                             -fx-background-radius: 8;"/>
        </VBox>
    </HBox>


    <HBox spacing="12">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Téléphone *"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <TextField fx:id="telephoneField" promptText="ex: 77 000 00 00"
                       style="-fx-background-color: #16213e;
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #606080;
                              -fx-background-radius: 8;
                              -fx-border-color: #0f3460;
                              -fx-border-radius: 8; -fx-border-width: 1;
                              -fx-padding: 8 12 8 12;"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Email"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <TextField fx:id="emailField" promptText="email@exemple.com"
                       style="-fx-background-color: #16213e;
                              -fx-text-fill: white;
                              -fx-prompt-text-fill: #606080;
                              -fx-background-radius: 8;
                              -fx-border-color: #0f3460;
                              -fx-border-radius: 8; -fx-border-width: 1;
                              -fx-padding: 8 12 8 12;"/>
        </VBox>
    </HBox>


    <VBox spacing="6">
        <Label text="Adresse"
               style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
        <TextField fx:id="adresseField" promptText="Adresse complète"
                   style="-fx-background-color: #16213e;
                          -fx-text-fill: white;
                          -fx-prompt-text-fill: #606080;
                          -fx-background-radius: 8;
                          -fx-border-color: #0f3460;
                          -fx-border-radius: 8; -fx-border-width: 1;
                          -fx-padding: 8 12 8 12;"/>
    </VBox>


    <HBox spacing="12">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Groupe sanguin"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <ComboBox fx:id="groupeSanguinField" maxWidth="Infinity"
                      style="-fx-background-color: #16213e;
                             -fx-border-color: #0f3460;
                             -fx-border-radius: 8; -fx-border-width: 1;
                             -fx-background-radius: 8;"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Rhésus"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <ComboBox fx:id="rehsusField" maxWidth="Infinity"
                      style="-fx-background-color: #16213e;
                             -fx-border-color: #0f3460;
                             -fx-border-radius: 8; -fx-border-width: 1;
                             -fx-background-radius: 8;"/>
        </VBox>
    </HBox>


    <VBox spacing="6">
        <Label text="Antécédents médicaux"
               style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
        <TextArea fx:id="antecedentsField"
                  promptText="Antécédents médicaux..."
                  prefRowCount="3" wrapText="true"
                  style="-fx-background-color: #16213e;
                         -fx-text-fill: white;
                         -fx-prompt-text-fill: #606080;
                         -fx-background-radius: 8;
                         -fx-border-color: #0f3460;
                         -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-padding: 8 12 8 12;"/>
    </VBox>


    <Label fx:id="errorLabel" text=""
           style="-fx-text-fill: #e94560; -fx-font-size: 12px;"
           wrapText="true"/>

    <Separator style="-fx-background-color: #0f3460;"/>


    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#annuler"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #a0a0b0;
                       -fx-border-color: #0f3460; -fx-border-width: 1;
                       -fx-border-radius: 8; -fx-background-radius: 8;
                       -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
        <Button fx:id="saveBtn" text="Enregistrer" onAction="#sauvegarder"
                style="-fx-background-color: #e94560;
                       -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>