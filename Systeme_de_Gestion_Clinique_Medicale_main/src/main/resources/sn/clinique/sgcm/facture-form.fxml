<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.clinique.sgcm.controller.FactureFormController"
      style="-fx-background-color: #1a1a2e;"
      spacing="16" prefWidth="460">

    <padding><Insets top="24" left="28" right="28" bottom="24"/></padding>

    <Label text="🧾 Générer une Facture"
           style="-fx-text-fill: white; -fx-font-size: 18px;
                  -fx-font-weight: bold;"/>

    <Separator style="-fx-background-color: #0f3460;"/>


    <VBox spacing="6"
          style="-fx-background-color: #0f3460; -fx-background-radius: 8;
                 -fx-padding: 12;">
        <Label text="INFORMATIONS CONSULTATION"
               style="-fx-text-fill: #a0c4ff; -fx-font-size: 11px;
                      -fx-font-weight: bold;"/>
        <HBox spacing="8">
            <Label text="Patient :"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <Label fx:id="infoPatient" text="—"
                   style="-fx-text-fill: white; -fx-font-size: 12px;"/>
        </HBox>
        <HBox spacing="8">
            <Label text="Médecin :"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <Label fx:id="infoMedecin" text="—"
                   style="-fx-text-fill: white; -fx-font-size: 12px;"/>
        </HBox>
        <HBox spacing="8">
            <Label text="Diagnostic :"
                   style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
            <Label fx:id="infoDiagnostic" text="—"
                   style="-fx-text-fill: white; -fx-font-size: 12px;"
                   wrapText="true"/>
        </HBox>
    </VBox>


    <VBox spacing="6">
        <Label text="Montant (FCFA) *"
               style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
        <TextField fx:id="montantField"
                   promptText="ex: 15000"
                   style="-fx-background-color: #16213e;
                          -fx-text-fill: white;
                          -fx-prompt-text-fill: #606080;
                          -fx-background-radius: 8;
                          -fx-border-color: #0f3460;
                          -fx-border-radius: 8; -fx-border-width: 1;
                          -fx-padding: 8 12 8 12;"/>
    </VBox>


    <VBox spacing="6">
        <Label text="Mode de paiement *"
               style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
        <ComboBox fx:id="modePaiementField" maxWidth="Infinity"
                  style="-fx-background-color: #16213e;
                         -fx-border-color: #0f3460;
                         -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-background-radius: 8;"/>
    </VBox>


    <VBox spacing="6">
        <Label text="Statut paiement *"
               style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
        <ComboBox fx:id="statutField" maxWidth="Infinity"
                  style="-fx-background-color: #16213e;
                         -fx-border-color: #0f3460;
                         -fx-border-radius: 8; -fx-border-width: 1;
                         -fx-background-radius: 8;"/>
    </VBox>


    <Label fx:id="errorLabel" text=""
           style="-fx-text-fill: #e94560; -fx-font-size: 12px;"
           wrapText="true"/>

    <Separator style="-fx-background-color: #0f3460;"/>


    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#annuler"
                style="-fx-background-color: transparent;
                       -fx-text-fill: #a0a0b0;
                       -fx-border-color: #0f3460; -fx-border-width: 1;
                       -fx-border-radius: 8; -fx-background-radius: 8;
                       -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
        <Button text="Générer Facture" onAction="#sauvegarder"
                style="-fx-background-color: #e94560;
                       -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-background-radius: 8;
                       -fx-padding: 8 20 8 20; -fx-cursor: hand;"/>
    </HBox>

</VBox>