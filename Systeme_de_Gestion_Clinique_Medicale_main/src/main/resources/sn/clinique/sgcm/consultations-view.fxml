<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="sn.clinique.sgcm.controller.ConsultationController"
      style="-fx-background-color: #1a1a2e;"
      spacing="20" prefWidth="860" prefHeight="620">

    <padding><Insets top="24" left="24" right="24" bottom="24"/></padding>

    <!-- ===== HEADER ===== -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="🩺 Gestion des Consultations"
               style="-fx-text-fill: white; -fx-font-size: 20px;
                      -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="＋  Nouvelle Consultation"
                onAction="#ouvrirFormulaire"
                style="-fx-background-color: #e94560;
                       -fx-text-fill: white; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-padding: 8 16 8 16;
                       -fx-cursor: hand; -fx-font-size: 13px;"/>
    </HBox>

    <!-- ===== FILTRES ===== -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField"
                   promptText="🔍  Rechercher par patient..."
                   prefHeight="38" prefWidth="280"
                   style="-fx-background-color: #16213e;
                          -fx-text-fill: white;
                          -fx-prompt-text-fill: #606080;
                          -fx-background-radius: 8;
                          -fx-border-color: #0f3460;
                          -fx-border-radius: 8; -fx-border-width: 1;
                          -fx-padding: 8 14 8 14; -fx-font-size: 13px;"/>
        <Button text="Rechercher" onAction="#rechercher"
                style="-fx-background-color: #0f3460;
                       -fx-text-fill: white; -fx-background-radius: 8;
                       -fx-padding: 8 16 8 16; -fx-cursor: hand;"/>
        <Button text="Actualiser" onAction="#chargerConsultations"
                style="-fx-background-color: #16213e;
                       -fx-text-fill: #a0a0b0; -fx-background-radius: 8;
                       -fx-border-color: #0f3460; -fx-border-width: 1;
                       -fx-padding: 8 16 8 16; -fx-cursor: hand;"/>
    </HBox>

    <!-- ===== TABLE ===== -->
    <TableView fx:id="consultationTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: #16213e;
                      -fx-border-color: #0f3460;
                      -fx-border-radius: 8; -fx-background-radius: 8;">
        <columns>
            <TableColumn fx:id="colDate"       text="Date"         prefWidth="100"/>
            <TableColumn fx:id="colPatient"    text="Patient"      prefWidth="150"/>
            <TableColumn fx:id="colMedecin"    text="Médecin"      prefWidth="150"/>
            <TableColumn fx:id="colDiagnostic" text="Diagnostic"   prefWidth="180"/>
            <TableColumn fx:id="colPrix"       text="Prix (FCFA)"  prefWidth="100"/>
            <TableColumn fx:id="colFacture"    text="Facture"      prefWidth="90"/>
            <TableColumn fx:id="colActions"    text="Actions"      prefWidth="150"/>
        </columns>
        <placeholder>
            <Label text="Aucune consultation trouvée"
                   style="-fx-text-fill: #a0a0b0;"/>
        </placeholder>
    </TableView>

    <!-- FOOTER -->
    <HBox alignment="CENTER_LEFT">
        <Label fx:id="totalLabel" text="Total : 0 consultation(s)"
               style="-fx-text-fill: #a0a0b0; -fx-font-size: 12px;"/>
    </HBox>

</VBox>